{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c 'uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}'",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "healthchecks": {
      "liveness": {
        "initialDelaySeconds": 30,
        "periodSeconds": 10
      }
    }
  }
}
