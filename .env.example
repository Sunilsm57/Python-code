# Database Configuration
# Railway Format: postgresql://username:password@autorack.proxy.rlwy.net:port/database_name
DATABASE_URL=postgresql://postgres:your-password@autorack.proxy.rlwy.net:19017/railway

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:4200,https://yourdomain.com

# Email Service (if applicable)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_TITLE=Your API
API_VERSION=1.0.0
API_DESCRIPTION=Your API Description
